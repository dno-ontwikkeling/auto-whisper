<Window x:Class="AutoWhisper.Views.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recording"
        Width="220" Height="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Border CornerRadius="12"
            Background="#E6202020"
            Padding="16,8"
            BorderBrush="#44FFFFFF"
            BorderThickness="1">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Sine wave bars -->
            <Canvas Width="100" Height="32" VerticalAlignment="Center" Margin="0,0,12,0">
                <Rectangle x:Name="Bar0" Canvas.Left="2"  Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.00"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.00"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar1" Canvas.Left="10" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.08"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.08"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar2" Canvas.Left="18" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.16"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.16"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar3" Canvas.Left="26" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.24"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.24"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar4" Canvas.Left="34" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.32"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.32"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar5" Canvas.Left="42" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.40"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.40"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar6" Canvas.Left="50" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.48"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.48"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar7" Canvas.Left="58" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.56"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.56"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar8" Canvas.Left="66" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.64"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.64"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar9" Canvas.Left="74" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.72"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.72"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar10" Canvas.Left="82" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.80"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.80"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
                <Rectangle x:Name="Bar11" Canvas.Left="90" Width="4" Height="8" RadiusX="2" RadiusY="2" Fill="#60A5FA" Canvas.Top="12">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="28" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.88"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="13" To="2" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.88"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
            </Canvas>

            <!-- Timer text -->
            <TextBlock x:Name="TimerText"
                       Text="0:00"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
